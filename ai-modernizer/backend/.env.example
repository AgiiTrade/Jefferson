# AI Modernizer backend production environment
NODE_ENV=production
PORT=3100
JWT_SECRET=replace-with-a-long-random-secret
DB_PATH=./data/ai-modernizer.db
ALLOWED_ORIGINS=https://agiitrade.github.io,https://your-production-domain.com
ANALYZE_RATE_LIMIT_MAX=25
CONTACT_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_MAX=12
RATE_LIMIT_WINDOW_MS=900000
ACCESS_LOG_ENABLED=true
SLOW_REQUEST_MS=1500
HEALTHCHECK_TIMEOUT_MS=1500
